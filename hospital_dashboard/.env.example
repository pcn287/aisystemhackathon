# Copy to .env and fill in. Do not commit .env.

# Supabase (required for dashboard data)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key
# Or: SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# LLM / AI Assistant (optional)
OPENAI_API_KEY=
OPENAI_BASE_URL=
LLM_MODEL=gpt-4o-mini

# Debug: set DEBUG=1 to enable DB_DEBUG (log each query + row count + time ms)
# DEBUG=
